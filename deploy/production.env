# Production Environment Variables for ThirdParty Platform
# Copy this file to .env in your production environment

# Application Settings
NODE_ENV=production
PORT=3001

# Database Settings (will be set by deployment platform)
# DATA_DIRECTORY=/app/data

# Security Settings
# Add your own secure admin credentials in production
ADMIN_EMAIL=henrylloyd190@gmail.com
ADMIN_PASSWORD=Ae123456@1

# File Upload Settings
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# CORS Settings (adjust for your domain)
ALLOWED_ORIGINS=*

# Logging
LOG_LEVEL=info

# Health Check
HEALTH_CHECK_ENDPOINT=/api/health
